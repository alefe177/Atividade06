programa {
  funcao inicio() {
    real n1, n2, n3, media
    escreva("digite o primeiro numero:")
   leia(n1)
    escreva("digite o segundo numero:")
    leia(n2)
    escreva("digite o terceiro numero:")
    leia(n3)
    media = (n1 + n2 + n3 ) / 3
    escreva("a media aritimetica e:" , media)
	
  }
}
