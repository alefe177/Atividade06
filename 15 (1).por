programa {
  funcao inicio() {
   
	
  inteiro base, expoente, i, resultado 


   escreva("Digite a base: ")
   leia(base)

   escreva("Digite o expoente: ")
   leia(expoente)

   resultado = <- 1

   para i de 1 ate expoente faca
      resultado <- (resultado * base)

   escreva("Resultado: ", resultado")



  }
}
